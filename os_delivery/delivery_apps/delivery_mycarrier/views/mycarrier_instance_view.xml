<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>

        <record id="mycarrier_instance_action" model="ir.actions.act_window">
            <field name="name">MyCarrier Instance</field>
            <field name="res_model">mycarrier.instance</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="mycarrier_instance_list_view" model="ir.ui.view">
            <field name="name">mycarrier.instance.list.view</field>
            <field name="model">mycarrier.instance</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="connect_state" />
                    <field name="account_id" />
                </list>
            </field>
        </record>

        <record id="mycarrier_instance_form_view" model="ir.ui.view">
            <field name="name">mycarrier.instance.form.view</field>
            <field name="model">mycarrier.instance</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Test Connection" class="btn btn-primary" name="check_connection_access" type="object" />
                        <field name="connect_state" widget="statusbar" statusbar_visible="draft,confirm"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Connected" invisible="connect_state != 'confirm'"/>
                        <group>
                            <field name="name"/>
                            <field name="delivery_product_id" required="1"/>
                        </group>
                        <notebook>
                            <page string="Credentials">
                                <group>
                                    <field name="account_id"/>
                                    <field name="token" password="True"/>
                                </group>
                            </page>
                            <page string="Products">
                                <field name="product_mapping_ids">
                                    <list edit="1" create="1" delete="1" editable="bottom">
                                        <field name="product_id"/>
                                        <field name="sku" />
                                        <field name="mycarrier_product_id" />
                                    </list>
                                </field>
                            </page>
                            <page string="Webhooks">
                                <field name="registered_webhook_ids" readonly="1">
                                    <list>
                                        <field name="webhook_environment"/>
                                        <field name="webhook_username" />
                                        <field name="webhook_customerid" />
                                        <field name="webhook_type" />
                                        <field name="webhook_uri" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <menuitem id="mycarrier_instance_menu" name="MyCarrier" parent="stock.menu_delivery" action="mycarrier_instance_action"/>
    </data>
</odoo>
