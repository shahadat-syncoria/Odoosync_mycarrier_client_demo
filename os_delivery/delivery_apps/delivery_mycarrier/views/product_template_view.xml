<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="product_template_form_view_inherit_mycarrier" model="ir.ui.view">
            <field name="name">product.template.form.view.inherit.mycarrier</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='group_lots_and_weight']" position="after">
                    <group string="MyCarrier" name="mycarrier_commodity">
                        <field name="mycarrier_commodity_class"/>
                        <field name="mycarrier_commodity_nmfc"/>
                        <field name="mycarrier_commodity_sub"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
